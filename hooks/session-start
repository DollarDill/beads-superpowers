#!/usr/bin/env bash
# SessionStart hook for beads-superpowers plugin
# This hook subsumes both superpowers skill injection AND beads context (bd prime).
# If bd prime is already registered as a hook elsewhere (e.g. bd setup claude),
# we skip our bd prime call to avoid duplicate context injection.

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

BSP_MEM_CEILING=8192
# Claude Code persists any hook output's additionalContext OUT-OF-LINE above
# 10,000 chars (hard-coded, per-hook-output, not configurable):
#   https://code.claude.com/docs/en/hooks   (verified 2026-07-12, ADR-0052)
# Symptom of rot: session start shows a <persisted-output> pointer instead of
# inline context. Fallback ladder: if the E2E probe persists, drop to 8500.
BSP_ENVELOPE_BUDGET=9500
# Reserved bytes around/inside the beads side that the memory ceiling does NOT
# count: wrapper joins ("\n\n<beads-context>\n" … "\n</beads-context>" ≈ 37B)
# plus the composer's fixed frame — section header (~30B), +N-over-budget tail
# (≤60B), disclosure line (≤170B), and the worst-case tier-2 escalation
# directive (≤340B) — rounded up for slack. Enforced by the overflow fixture in
# tests/hooks/test-bootstrap-budget.sh.
BSP_WRAP_OVERHEAD=768

# Selection input is `bd memories --json`: one `"key": "body"` entry per line
# (verified shape, bd v1.1.0) with the FULL body inline — immune to the plain
# listing's preview truncation, which can hide a late @salience token.
# Emits "<salience>\t<key>" for @salience=4|5 entries. Anchored to the
# `@type=…` header run (before the first `\n`) so a body mention of
# `@salience=` cannot false-select.
bsp_select_memory_keys() {
    sed -n 's/^[[:space:]]*"\([^"]*\)":[[:space:]]*"@type=[^\\]*@salience=\([45]\).*/\2\t\1/p'
}

# Lexically-latest continuation-* key from the same JSON listing (dates sort lexically).
bsp_latest_continuation() {
    sed -n 's/^[[:space:]]*"\(continuation-[^"]*\)":.*/\1/p' | sort | tail -1
}

# Two-tier memory-backlog escalation (ADR-0052). Tier 2 (>= ESCALATE_AT) injects a
# file-ONE-deduped-bead directive; tier 1 is the soft sweep nudge. if/elif => never stack.
bsp_backlog_lines() {
    local count="$1" nudge_at="${BSP_MEM_NUDGE_AT:-150}" escalate_at="${BSP_MEM_ESCALATE_AT:-300}"
    if [ "$count" -ge "$escalate_at" ]; then
        # shellcheck disable=SC2016  # backticks are literal markdown code-format markers, not expansions
        printf 'memory store at %s (>= %s): check for an open memory-curation bead (`bd query "status=open"`, titles matching "memory-curator sweep"); if none exists, file ONE chore bead — `bd create "Run memory-curator sweep: store at %s memories" -t chore` with the agent-filed stamp — then continue with the current work. Never file a duplicate.\n' "$count" "$escalate_at" "$count"
    elif [ "$count" -ge "$nudge_at" ]; then
        # shellcheck disable=SC2016
        printf 'store at %s memories (>= %s) — run the memory-curator sweep to consolidate/route.\n' "$count" "$nudge_at"
    fi
}

# Compose the memories section under a byte ceiling.
# $1 = ceiling bytes. Uses `bd memories --json` (selection) + `bd recall` (bodies).
bsp_compose_memories() {
    local ceiling="$1" listing total_count selected cont section="" used=0 skipped=0 injected=0
    listing=$(bd memories --json 2>/dev/null) || listing=""
    [ -z "$listing" ] && return 0
    total_count=$(printf '%s\n' "$listing" | grep -cE '^[[:space:]]*"[^"]+":' || true)

    # Pure-bash probe — a `printf | grep -q` pipeline here SIGPIPEs under
    # pipefail when the listing exceeds the 64KB pipe buffer and matches early
    # (grep exits, printf's next write dies 141), misfiring this branch.
    if [[ "$listing" != *"@salience="* ]]; then
        printf '## Persistent Memories\n\n%s memories stored, none curated yet — ' "$total_count"
        printf 'run the memory-curator curation sweep to choose what is ambient. '
        # shellcheck disable=SC2016  # backticks are literal markdown code-format markers, not expansions
        printf 'Search: `bd memories <keyword>` · fetch: `bd recall <key>`\n'
        bsp_backlog_lines "$total_count"
        return 0
    fi

    cont=$(printf '%s\n' "$listing" | bsp_latest_continuation)
    selected=$(printf '%s\n' "$listing" | bsp_select_memory_keys)
    [ -n "$cont" ] && selected=$(printf '9\t%s\n%s' "$cont" "$selected" | awk '!seen[$2]++')

    local sal key body entry len
    while IFS=$'\t' read -r sal key; do
        [ -z "$key" ] && continue
        body=$(bd recall "$key" 2>/dev/null) || continue
        entry="### ${key}
${body}

"
        len=$(printf '%s' "$entry" | wc -c)  # FULL section BYTES: header+body+scaffolding (ADR-0052); not ${#var} — UTF-8
        if [ $((used + len)) -gt "$ceiling" ]; then
            if [ "$sal" = "9" ]; then
                # continuation: first claim on the allowance, but no bypass —
                # degrade to a pointer line that preserves the key (ADR-0052)
                # shellcheck disable=SC2016  # backticks are literal markdown code-format markers, not expansions
                entry="continuation over budget — \`bd recall ${key}\`
"
                section="${section}${entry}"
                used=$((used + $(printf '%s' "$entry" | wc -c)))
            fi
            skipped=$((skipped + 1)); continue
        fi
        section="${section}${entry}"
        used=$((used + len)); injected=$((injected + 1))
    done <<<"$(printf '%s\n' "$selected" | sort -t$'\t' -k1,1nr)"

    printf '## Persistent Memories (core)\n\n%s' "$section"
    # shellcheck disable=SC2016  # backticks are literal markdown code-format markers, not expansions
    [ "$skipped" -gt 0 ] && printf '+%s more core memories over budget — `bd memories <kw>`\n' "$skipped"
    # shellcheck disable=SC2016  # backticks are literal markdown code-format markers, not expansions
    printf 'core memories: %s of %s injected (salience>=4 + latest continuation, %s-byte budget) — search the rest: `bd memories <keyword>` · fetch: `bd recall <key>`\n' \
        "$injected" "$total_count" "$ceiling"
    bsp_backlog_lines "$total_count"
}

# Static bd workflow pointer (onboard-style; ~250 tok)
bsp_bd_pointer() {
    cat <<'PTR'
## Issue Tracking (bd)

This workspace uses **bd (beads)**. Core commands:
- `bd ready -n 10` — unblocked work · `bd show --short <id>` — skim an issue
- `bd create "Title" -t task -p 2` — create · `bd close <id> --reason "..."` — complete
- `bd query "status=open"` — search · `bd remember "insight"` — persist a memory
- `bd batch` / `bd create --graph` — many writes, one call
Commands: `bd human` · syntax: `bd <cmd> --help` on first use — the binary is SSOT · conventions: the `tracking-with-beads` skill. If beads context was not injected this session: `bd prime`.
PTR
}

# Test seam: when sourced with BSP_SOURCED=1, expose functions and stop.
if [ "${BSP_SOURCED:-0}" = "1" ]; then
    # shellcheck disable=SC2317  # exit 0 is the non-sourced fallback; unreachable when `.`-sourced
    return 0 2>/dev/null || exit 0
fi

# --- flag parsing (before any output) ---
BSP_EMIT_PLAIN=0
for arg in "$@"; do
    [ "$arg" = "--emit-plain" ] && BSP_EMIT_PLAIN=1
done

# --- event-scoped dedup (same event, multiple registrations; jb3u) ---
# Read hook stdin JSON if present. Bounded on both axes — 2s per read, 64KB total —
# so a TTY, a never-closing pipe, or a firehose can never hang or bloat the hook
# (bash builtin read only; no coreutils-timeout dependency).
bsp_stdin=""
if [ ! -t 0 ]; then
    bsp_line=""
    while IFS= read -r -t 2 bsp_line; do
        bsp_stdin="${bsp_stdin}${bsp_line}"
        [ "${#bsp_stdin}" -ge 65536 ] && break
    done
    bsp_stdin="${bsp_stdin}${bsp_line}"   # capture final unterminated line (read rc=1 leaves partial content)
fi
bsp_sid=$(printf '%s' "$bsp_stdin" | sed -n 's/.*"session_id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | tr -cd 'a-zA-Z0-9_-' | cut -c1-64)
bsp_src=$(printf '%s' "$bsp_stdin" | sed -n 's/.*"source"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'     | tr -cd 'a-zA-Z0-9_-' | cut -c1-32)
# PPID-keyed fallback: duplicate registrations for the SAME event share a parent
# (the harness process) → still dedup; different sessions = different harness
# processes (different PPIDs) → never collide on one global "nosid" bucket.
[ -z "$bsp_sid" ] && bsp_sid="nosid-$PPID"
[ -z "$bsp_src" ] && bsp_src="unknown"

bsp_marker_dir="${XDG_RUNTIME_DIR:-/tmp}/beads-superpowers-$(id -u)"
bsp_marker="$bsp_marker_dir/m-${bsp_sid}-${bsp_src}"
bsp_suppress=0
if mkdir -p "$bsp_marker_dir" 2>/dev/null && chmod 700 "$bsp_marker_dir" 2>/dev/null; then
    if [ -L "$bsp_marker" ]; then
        : # symlink planted — refuse to touch it, fail open (inject)
    elif ( set -C; : > "$bsp_marker" ) 2>/dev/null; then
        : # we own this event — inject
    elif [ -n "$(find "$bsp_marker" -mmin -1 2>/dev/null)" ]; then
        bsp_suppress=1   # sibling registration beat us within the 60s TTL
    else
        touch "$bsp_marker" 2>/dev/null || true   # stale marker — refresh, inject
    fi
fi
if [ "$bsp_suppress" = "1" ]; then
    if [ "$BSP_EMIT_PLAIN" = "1" ]; then exit 0; fi
    printf '{}\n'; exit 0
fi

# --- bd prime safety net: lean override where the composer owns injection ---
if command -v bd >/dev/null 2>&1 && [ -d .beads ] && [ ! -e .beads/PRIME.md ] && [ ! -L .beads/PRIME.md ]; then
    # Same class as the salience probe: `<output> | grep -q` under pipefail is
    # SIGPIPE-prone — capture then match in bash (same ERE, no pipe).
    bsp_cfg=$(bd config show 2>/dev/null) || bsp_cfg=""
    bsp_net_off='custom\.prime-safety-net[[:space:]]*=[[:space:]]*false'
    if ! [[ "$bsp_cfg" =~ $bsp_net_off ]]; then
        cat > .beads/PRIME.md <<'NET' || true
<!-- Written by the beads-superpowers plugin (safety net).
     Your session hook injects a curated beads context, so `bd prime` here
     returns this lean pointer instead of the full memory dump.
     To restore full `bd prime` output: delete this file.
     To stop it being recreated: bd config set custom.prime-safety-net false -->
# Beads Workflow (lean pointer)
Session context is injected by the beads-superpowers hook.
- Work queue: `bd ready -n 10` · commands: `bd human` · syntax: `bd <cmd> --help` first (the binary is SSOT) · conventions: `tracking-with-beads` skill
- Memories: `bd memories <keyword>` · one memory: `bd recall <key>`
- Full default prime content: `bd prime --export`
NET
    fi
fi

# Check if legacy skills directory exists and build warning
warning_message_raw=""
legacy_skills_dir="${HOME}/.config/superpowers/skills"
if [ -d "$legacy_skills_dir" ]; then
    warning_message_raw="

<important-reminder>IN YOUR FIRST REPLY AFTER SEEING THIS MESSAGE YOU MUST TELL THE USER:⚠️ **WARNING:** Superpowers now uses Claude Code's skills system. Custom skills in ~/.config/superpowers/skills will not be read. Move custom skills to ~/.claude/skills instead. To make this message go away, remove ~/.config/superpowers/skills</important-reminder>"
fi

# Detect if bd prime is already registered as a hook elsewhere (e.g. bd setup claude).
# Check project and global settings files — if found, skip our bd prime call.
bd_prime_already_hooked=0
for settings_file in \
    ".claude/settings.json" \
    ".claude/settings.local.json" \
    "${HOME}/.claude/settings.json" \
    "${HOME}/.claude/settings.local.json"; do
    if [ -f "$settings_file" ] 2>/dev/null && grep -q '"bd prime"' "$settings_file" 2>/dev/null; then
        bd_prime_already_hooked=1
        break
    fi
done

# Read using-superpowers content
using_superpowers_content=$(cat "${PLUGIN_ROOT}/skills/using-superpowers/SKILL.md" 2>/dev/null) || using_superpowers_content="beads-superpowers: using-superpowers skill unreadable"

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Build combined session context: skills + beads workflow.
# RAW strings only (real newlines) — escape_for_json is applied exactly once,
# at the output boundary below, per dialect.
session_context_raw="<EXTREMELY_IMPORTANT>
You have beads-superpowers.

**Below is the full content of your 'beads-superpowers:using-superpowers' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**

${using_superpowers_content}
${warning_message_raw}
</EXTREMELY_IMPORTANT>"

# Compose beads section AFTER measuring the bootstrap side — the beads side gets
# exactly the remainder of the total envelope budget (ADR-0052). min() lives HERE,
# in the caller; bsp_compose_memories keeps its plain <ceiling> signature.
# (Skipped if an external bd prime hook owns injection.)
beads_context=""
if [ "$bd_prime_already_hooked" -eq 0 ] && command -v bd &>/dev/null && bd memories --json >/dev/null 2>&1; then
    bsp_pointer="$(bsp_bd_pointer)"
    bsp_allowance=$(( BSP_ENVELOPE_BUDGET - $(printf '%s' "$session_context_raw" | wc -c) \
                      - $(printf '%s' "$bsp_pointer" | wc -c) - BSP_WRAP_OVERHEAD ))
    [ "$bsp_allowance" -lt 0 ] && bsp_allowance=0
    bsp_mem_ceiling=$(( bsp_allowance < BSP_MEM_CEILING ? bsp_allowance : BSP_MEM_CEILING ))
    beads_context="${bsp_pointer}

$(bsp_compose_memories "$bsp_mem_ceiling")"
fi

# Append beads context if available
if [ -n "$beads_context" ]; then
    session_context_raw="${session_context_raw}

<beads-context>
${beads_context}
</beads-context>"
fi

# Output context injection.
# --emit-plain: raw text, no JSON envelope (consumed by OpenCode plugin / install.sh shims).
# Cursor hooks expect additional_context (snake_case).
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# CLAUDE_PROJECT_DIR covers settings.json-registered hooks (Claude Code sets it
# on every hook invocation; plugin-channel invocations also get CLAUDE_PLUGIN_ROOT).
# Copilot CLI (v1.0.11+) and others expect additionalContext (top-level, SDK standard).
if [ "$BSP_EMIT_PLAIN" = "1" ]; then
  printf '%s\n' "$session_context_raw"
elif [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$(escape_for_json "$session_context_raw")"
elif { [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] || [ -n "${CODEX_PLUGIN_ROOT:-}" ] || [ -n "${CLAUDE_PROJECT_DIR:-}" ]; } && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$(escape_for_json "$session_context_raw")"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$(escape_for_json "$session_context_raw")"
fi

# bd-absent hint (non-fatal, one line to stderr)
if ! command -v bd >/dev/null 2>&1; then
  printf '%s\n' "beads not found — install bd to enable persistent task memory: https://github.com/DollarDill/beads-superpowers#prerequisites" >&2
fi

# upstream-superpowers coexistence collision warning (best-effort, non-fatal)
_bsp_plugins="$HOME/.claude/plugins/installed_plugins.json"
if grep -Eq '"superpowers@(claude-plugins-official|superpowers-marketplace)"' "$_bsp_plugins" 2>/dev/null; then
  printf '%s\n' "warning: obra/superpowers appears installed alongside beads-superpowers — skill names collide; use one or the other" >&2
fi

exit 0
